# Copy this file to .env for local testing (never commit the real .env)
# On Render, set these under your service's "Environment" tab instead.

# Required — from the Discord Developer Portal > Your App > Bot > Token
DISCORD_TOKEN=your_bot_token_here

# Required — from Discord Developer Portal > Your App > General Information > Application ID
CLIENT_ID=your_application_client_id_here

# Optional — set this to your server's ID while testing so slash commands
# register instantly (global commands can take up to 1 hour to show up).
# Leave blank/remove it once you're ready to deploy to production.
GUILD_ID=your_test_server_id_here

# Optional — override contest timing (in minutes)
CAPTION_SUBMIT_MINUTES=10
CAPTION_VOTE_MINUTES=5
